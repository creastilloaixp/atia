# ============================================
# CastoProject — Environment Variables Template
# ============================================
# Copia este archivo como .env y rellena tus keys:
#   cp .env.example .env

# --- Frontend (Vite exposes VITE_ prefixed vars) ---
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_N8N_API_KEY=your_n8n_api_key_here

# --- Marketing Automation (Antigravity + Blotato) ---
GEMINI_API_KEY=your_gemini_api_key_here
N8N_BASE_URL=https://your-n8n-instance.com
BLOTATO_API_KEY=your_blotato_api_key_here

# --- Opcional ---
# CDP_HOST=localhost
# CDP_PORT=9222
