# ==============================================================================
# CASTOPROJECT - .gitignore
# ==============================================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
dist-ssr/
build/
out/

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.*.local
.env.production
.env.development

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Editor directories
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Vite cache
.vite/

# TypeScript
*.tsbuildinfo

# Supabase local
.supabase/

# Test outputs
test-results/
playwright-report/
coverage/
