        "specifyBody": "json",
        "jsonBody": "={\n  \"name\": \"Lead Casto: {{ $json.name }} - {{ $json.intent }}\",\n  \"custom_fields_values\": [\n    {\n      \"field_id\": \"ID_CAMPO_TELEFONO\",\n      \"values\": [{ \"value\": \"{{ $json.phone_display }}\" }]\n    }\n  ]\n}",
        "options": {}
      },
