            {
              "id": "check-valid",
              "leftValue": "={{ $json.valid }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-valid",
      "name": "Datos Validos",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [560, 304]
    },
