        "options": {}
      },
      "id": "a150723f-b8da-4c73-aa72-64330a290aa2",
      "name": "Webhook - Lead Landing",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 304],
      "webhookId": "e0ece7eb-a875-41ba-9463-d37fea889ed1"
    },
    {
      "parameters": {
        "jsCode": "// Validar campos requeridos del lead\nconst body = $input.first().json.body || {};\nconst contact = body.contact || {};\nconst details = body.lead_details || {};\n\nconst phone = (contact.phone || '').toString().trim();\nconst name = (contact.name || '').toString().trim();\n\n// Validar teléfono\nif (!phone || phone.replace(/[^0-9]/g, '').length < 7) {\n  return [{\n    json: {\n      valid: false,\n      error: 'Teléfono inválido o vacío (mín 7 dígitos)'\n    }\n  }];\n}\n\n// Validar nombre\nif (!name || name.length < 2) {\n  return [{\n    json: {\n      valid: false,\n      error: 'Nombre requerido (mín 2 caracteres)'\n    }\n  }];\n}\n\n// Normalizar teléfono MX: asegurar formato 52XXXXXXXXXX\nlet cleanPhone = phone.replace(/[^0-9]/g, '');\nif (!cleanPhone.startsWith('52') && cleanPhone.length === 10) {\n  cleanPhone = '52' + cleanPhone;\n} else if (cleanPhone.startsWith('1') && cleanPhone.length === 11) {\n  cleanPhone = '52' + cleanPhone.slice(1);\n}\n\nreturn [{\n  json: {\n    valid: true,\n    name: name,\n    phone: cleanPhone,\n    phone_display: '+' + cleanPhone,\n    intent: details.intent || 'general',\n    property_value: details.property_value || 'no_especificado',\n    source: body.source || 'Landing Casto',\n    campaign: body.campaign || 'general',\n    timestamp: body.timestamp || new Date().toISOString()\n  }\n}];"
      },
      "id": "code-validate",
      "name": "Validar y Normalizar",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [304, 304]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 1
          },
